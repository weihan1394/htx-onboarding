<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <!-- Exclude DB repositories, web-host wiring, and Broadcaster (DB-dependent) -->
          <ExcludeByFile>**/Program.cs,**/Repositories/**,**/Services/Broadcaster.cs</ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
