        <mxCell id="before-note" parent="1" style="rounded=1;html=1;whiteSpace=wrap;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" value="&lt;b&gt;Before (polling):&lt;/b&gt;&lt;br&gt;hr-web → GET /onboarding/{id} every 3 s&lt;br&gt;&lt;br&gt;&lt;b&gt;After (pub/sub):&lt;/b&gt;&lt;br&gt;hr-web opens SSE stream once&lt;br&gt;Updates arrive instantly on publish" vertex="1">
